---
import Base from "../layouts/Base.astro";
import StatusBadge from "../components/StatusBadge.astro";
import { loadCommitments, lastActivityDate, PILLAR_LABELS } from "../lib/commitments";

const commitments = loadCommitments();

const counts = commitments.reduce(
  (acc, c) => {
    acc[c.status] = (acc[c.status] ?? 0) + 1;
    return acc;
  },
  {} as Record<string, number>
);
---

<Base title="Scorecard">
  <h1>India-UK Vision 2035: Technology Scorecard</h1>
  <p class="strapline">
    Every tech-pillar commitment in the India-UK Vision 2035 framework, tracked
    against publicly available evidence. Updated weekly, reviewed by hand.
  </p>

  <div class="stats-bar">
    <span><strong>{counts.delivered ?? 0}</strong> delivered</span>
    <span><strong>{counts.in_progress ?? 0}</strong> in progress</span>
    <span><strong>{counts.announced_only ?? 0}</strong> announced only</span>
    <span><strong>{counts.no_public_evidence ?? 0}</strong> no public evidence</span>
    {counts.superseded ? <span><strong>{counts.superseded}</strong> superseded</span> : null}
  </div>

  <table class="scorecard">
    <thead>
      <tr>
        <th>Commitment</th>
        <th>Pillar</th>
        <th>Status</th>
        <th>Evidence</th>
        <th>Last activity</th>
      </tr>
    </thead>
    <tbody>
      {commitments.map((c) => (
        <tr>
          <td><a href={`/commitment/${c.id}/`}>{c.title}</a></td>
          <td class="pillar-tag">{PILLAR_LABELS[c.pillar]}</td>
          <td><StatusBadge status={c.status} /></td>
          <td>{c.evidence?.length ?? 0}</td>
          <td>{lastActivityDate(c)}</td>
        </tr>
      ))}
    </tbody>
  </table>
</Base>
